# ==========================================
# ChinaWise - Environment Configuration Template
# ==========================================
# Copy this file to .env and fill in your actual values

# ==========================================
# Database Configuration
# ==========================================
DB_USER=chinawise
DB_PASSWORD=your_secure_password_here
DB_NAME=chinawise
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public

# ==========================================
# Redis Configuration
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# JWT Configuration
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=2h

# ==========================================
# API Configuration
# ==========================================
NODE_ENV=production
PORT=3000
API_URL=https://api.yourdomain.com
WEB_URL=https://yourdomain.com

# ==========================================
# OpenRouter AI Configuration
# Get your API key from: https://openrouter.ai/keys
# ==========================================
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Optional: Fallback models (comma-separated)
OPENROUTER_FALLBACK_MODELS=openai/gpt-4o,google/gemini-pro

# ==========================================
# Stripe Payment Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
# ==========================================
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==========================================
# PayPal Payment Configuration
# Get your credentials from: https://developer.paypal.com/dashboard/
# ==========================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=live

# ==========================================
# Alibaba Cloud OSS Configuration
# Get your credentials from: https://www.alibabacloud.com/product/oss
# ==========================================
ALIBABA_OSS_ACCESS_KEY_ID=your_alibaba_access_key_id
ALIBABA_OSS_ACCESS_KEY_SECRET=your_alibaba_access_key_secret
ALIBABA_OSS_BUCKET=your-bucket-name
ALIBABA_OSS_REGION=oss-cn-hangzhou
ALIBABA_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ==========================================
# OAuth Configuration - Google
# Get credentials from: https://console.cloud.google.com/apis/credentials
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==========================================
# OAuth Configuration - Facebook
# Get credentials from: https://developers.facebook.com/apps/
# ==========================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ==========================================
# OAuth Configuration - Apple
# Get credentials from: https://developer.apple.com/account/resources/identifiers/list
# ==========================================
APPLE_CLIENT_ID=your.apple.bundle.id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nYour_Private_Key_Here\n-----END EC PRIVATE KEY-----

# ==========================================
# Rate Limiting Configuration
# ==========================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ==========================================
# Email Configuration (Optional - for notifications)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ==========================================
# Sentry Error Tracking (Optional)
# Get DSN from: https://sentry.io/
# ==========================================
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project-id

# ==========================================
# Google Analytics (Optional)
# ==========================================
GA_MEASUREMENT_ID=G-XXXXXXXXXX
