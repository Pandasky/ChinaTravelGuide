# Test Environment Configuration
NODE_ENV=test

# Use an in-memory or test database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chinawise_test?schema=public"

# JWT - use simple secrets for testing
JWT_SECRET="test-secret"
JWT_REFRESH_SECRET="test-refresh-secret"

# OpenRouter - can be mocked in tests
OPENROUTER_API_KEY="test-api-key"

# Stripe - use test keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_test..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# PayPal - use sandbox keys
PAYPAL_CLIENT_ID="test-client-id"
PAYPAL_CLIENT_SECRET="test-client-secret"

# Alibaba Cloud OSS - can be mocked
ALIYUN_ACCESS_KEY_ID="test-key-id"
ALIYUN_ACCESS_KEY_SECRET="test-key-secret"
ALIYUN_OSS_REGION="cn-hangzhou"
ALIYUN_OSS_BUCKET="chinawise-test"

# Frontend URL
FRONTEND_URL="http://localhost:5173"

# Server
PORT=3001
